<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Can We Ruin Our Friendship? 🌷</title>

<link rel="stylesheet" href="style.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
</head>

<body>

<div id="flowers"></div>
<div id="hearts"></div>

<div class="card">

<h1>🌷</h1>

<h2>CAN WE RUIN OUR FRIENDSHIP?</h2>

<p id="message">
Choose wisely... 💕
</p>

<div class="buttons">

<button id="yes">
YES 💖
</button>

<button id="no">
NO 🙈
</button>

</div>

</div>

<div id="celebrate" class="hidden">

<h1>💖 YAY!! 💖</h1>

<p>
I knew you'd say YES! 🌷
</p>

<div class="bigHeart">
❤️
</div>

</div>

<script src="script.js"></script>

</body>
</html>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    overflow:hidden;
    height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;

    background:linear-gradient(180deg,#ffd6e7,#ffeef5,#fff8fb);
}

/* Floating Decorations */

#flowers,
#hearts{
    position:fixed;
    inset:0;
    overflow:hidden;
    pointer-events:none;
}

.flower,
.heart{
    position:absolute;
    animation:floatUp linear infinite;
    opacity:.85;
}

.flower{
    font-size:30px;
}

.heart{
    font-size:24px;
}

@keyframes floatUp{

0%{
transform:translateY(110vh) rotate(0deg);
opacity:0;
}

10%{
opacity:1;
}

100%{
transform:translateY(-120vh) rotate(360deg);
opacity:0;
}

}

/* Card */

.card{

width:90%;
max-width:420px;

padding:40px;

text-align:center;

background:rgba(255,255,255,.45);

backdrop-filter:blur(14px);

border-radius:30px;

box-shadow:0 20px 50px rgba(255,105,180,.18);

animation:pop .8s;

}

@keyframes pop{

from{
transform:scale(.7);
opacity:0;
}

to{
transform:scale(1);
opacity:1;
}

}

.card h1{

font-size:70px;

}

.card h2{

margin-top:10px;

font-size:30px;

color:#ff4d94;

}

.card p{

margin:20px 0;

font-size:18px;

color:#555;

}

/* Buttons */

.buttons{

margin-top:30px;

position:relative;

height:120px;

}

button{

padding:15px 35px;

border:none;

border-radius:50px;

font-size:18px;

cursor:pointer;

transition:.25s;

position:absolute;

}

#yes{

left:40px;

background:#ff4d94;

color:white;

}

#yes:hover{

transform:scale(1.08);

}

#no{

right:40px;

background:white;

color:#ff4d94;

}

/* Celebration */

.hidden{

display:none;

}

#celebrate{

position:fixed;

inset:0;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

background:linear-gradient(#ffd6ea,#fff);

animation:fade .6s;

}

@keyframes fade{

from{

opacity:0;

}

to{

opacity:1;

}

}

#celebrate h1{

font-size:60px;

color:#ff3f8d;

}

#celebrate p{

font-size:28px;

margin-top:20px;

color:#444;

}

.bigHeart{

font-size:90px;

margin-top:30px;

animation:beat 1s infinite;

}

@keyframes beat{

50%{

transform:scale(1.25);

}

}
const yesBtn = document.getElementById("yes");
const noBtn = document.getElementById("no");
const msg = document.getElementById("message");

const card = document.querySelector(".card");
const celebrate = document.getElementById("celebrate");

const flowerContainer = document.getElementById("flowers");
const heartContainer = document.getElementById("hearts");

const messages = [
    "Awww... try again! 🥺",
    "Nope! You almost got it 😂",
    "The NO button is shy 🌷",
    "You can't catch me! 😜",
    "Just press YES already 💕",
    "Be nice 🥹",
    "I believe in you ❤️",
    "YES is the better choice 😆"
];

let index = 0;

// Floating Flowers
function createFlower(){

    const flower=document.createElement("div");

    flower.className="flower";

    flower.innerHTML="🌷";

    flower.style.left=Math.random()*100+"vw";

    flower.style.animationDuration=
    6+Math.random()*5+"s";

    flower.style.fontSize=
    20+Math.random()*25+"px";

    flowerContainer.appendChild(flower);

    setTimeout(()=>{
        flower.remove();
    },12000);

}

setInterval(createFlower,700);

// Floating Hearts

function createHeart(){

    const heart=document.createElement("div");

    heart.className="heart";

    heart.innerHTML="💖";

    heart.style.left=Math.random()*100+"vw";

    heart.style.animationDuration=
    5+Math.random()*4+"s";

    heart.style.fontSize=
    18+Math.random()*22+"px";

    heartContainer.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },10000);

}

setInterval(createHeart,500);

// NO Button Escape

noBtn.addEventListener("mouseover",moveButton);
noBtn.addEventListener("click",moveButton);

function moveButton(){

    const x=Math.random()*250-125;

    const y=Math.random()*150-75;

    noBtn.style.transform=
    `translate(${x}px,${y}px)`;

    msg.innerHTML=
    messages[index];

    index++;

    if(index>=messages.length){
        index=0;
    }

    yesBtn.style.transform=
    `scale(${1+(index*0.05)})`;

}

// YES Button

yesBtn.addEventListener("click",()=>{

    card.style.display="none";

    celebrate.classList.remove("hidden");

    // Celebration Hearts

    setInterval(()=>{

        const heart=document.createElement("div");

        heart.innerHTML="💖";

        heart.style.position="fixed";
        heart.style.left=Math.random()*100+"vw";
        heart.style.top="100vh";
        heart.style.fontSize=
        25+Math.random()*40+"px";
        heart.style.pointerEvents="none";
        heart.style.transition="5s linear";

        document.body.appendChild(heart);

        setTimeout(()=>{
            heart.style.top="-100px";
        },50);

        setTimeout(()=>{
            heart.remove();
        },5000);

    },150);

});
